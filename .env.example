# Copy this file to .env and fill in your values.

# ── Credentials (used for auto-login) ─────────────────────────────────────
APEC_EMAIL=you@example.com
APEC_PASSWORD=YourPassword

# ── Account IDs (stable, from your APEC profile URL) ──────────────────────
APEC_ID_COMPTE_CADRE=YOUR_COMPTE_CADRE_ID
APEC_ID_PROFIL_CADRE=YOUR_PROFIL_CADRE_ID

# ── Session file (optional, default: ~/.apec_session.json) ────────────────
# APEC_SESSION_FILE=/path/to/.apec_session.json

# ── Manual cookie override (optional — takes precedence over auto-login) ───
# Use this as a fallback if auto-login is blocked by DataDome.
# Network tab → any /cms/webservices/* request → Request Headers → Cookie
# APEC_COOKIES=JSESSIONID=XXXX; datadome=XXXX; apec.user.cookie=XXXX; apec_activity_cookie=XXXX; srv_id=XXXX

# ── MCP transport (leave as-is for Docker) ─────────────────────────────────
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080
